<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card">
      <div class="card-body">
        <h2 class="card-title mb-4">Upload New Spreadsheet</h2>

        <%= form_with(model: @spreadsheet, local: true, html: { class: 'needs-validation' }) do |f| %>
          <% if @spreadsheet.errors.any? %>
            <div class="alert alert-danger">
              <h4>The following errors prevented the spreadsheet from being saved:</h4>
              <ul class="mb-0">
                <% @spreadsheet.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :file, 'Select XLSX File', class: 'form-label' %>
            <%= f.file_field :file, 
                           class: 'form-control', 
                           accept: '.xlsx',
                           required: true,
                           data: { 
                             controller: 'file-upload',
                             action: 'change->file-upload#validateFile'
                           } %>
            <div class="form-text">Only .xlsx files are allowed</div>
          </div>

          <div class="d-grid gap-2">
            <%= f.submit 'Upload', class: 'btn btn-primary' %>
            <%= link_to 'Cancel', spreadsheets_path, class: 'btn btn-outline-secondary' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# Add client-side validation for file type %>
<%= javascript_tag do %>
  document.addEventListener('turbo:load', function() {
    const fileInput = document.querySelector('input[type="file"]');
    if (fileInput) {
      fileInput.addEventListener('change', function() {
        const file = this.files[0];
        if (file && !file.name.toLowerCase().endsWith('.xlsx')) {
          this.value = '';
          alert('Please select an XLSX file');
        }
      });
    }
  });
<% end %> 