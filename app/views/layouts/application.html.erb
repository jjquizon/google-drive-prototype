<!DOCTYPE html>
<html>
  <head>
    <title>Google Drive Spreadsheet Portal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
      <div class="container">
        <%= link_to 'Spreadsheet Portal', root_path, class: 'navbar-brand' %>
        <% if user_signed_in? %>
          <div class="navbar-nav ms-auto">
            <span class="nav-item nav-link text-light"><%= current_user.email %></span>
            <%= button_to 'Logout', logout_path, method: :delete, class: 'btn btn-outline-light' %>
          </div>
        <% end %>
      </div>
    </nav>

    <div class="container">
      <% flash.each do |name, msg| %>
        <% if name == "notice" %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% elsif name == "alert" %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
